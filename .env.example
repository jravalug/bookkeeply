# Ambiente
FLASK_ENV=dev
# Opciones: dev, test, prod

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Seguridad - CAMBIAR EN PRODUCCIÓN
SECRET_KEY=your-super-secret-key-change-in-production

# Base de datos
# Formato recomendado SQLAlchemy + psycopg:
# postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL_DEV=postgresql+psycopg://bookkeeply_dev:dev_password_change_me@localhost:5432/bookkeeply_dev
DATABASE_URL_TEST=postgresql+psycopg://bookkeeply_test:test_password_change_me@localhost:5432/bookkeeply_test
DATABASE_URL_PROD=postgresql+psycopg://bookkeeply_prod:prod_password_change_me@localhost:5432/bookkeeply_prod

# Docker Postgres (usado por docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookkeeply_dev
POSTGRES_USER=bookkeeply_dev
POSTGRES_PASSWORD=dev_password_change_me

# Redis (para caché y Celery)
REDIS_URL=redis://localhost:6379/0

# Celery - Message Broker y Result Backend
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
